<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tegula_bg_root"
    android:orientation="vertical"
    android:padding="@dimen/tegula_spacing_lg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/tegula_spacing_md"
        android:background="@drawable/tegula_card_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/tegula_spacing_md">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="From"
                android:textColor="@color/tegula_text_secondary"
                android:textSize="@dimen/tegula_text_xs"
                android:textStyle="bold" />

            <include
                android:id="@+id/sourceDropdown"
                layout="@layout/tegula_dropdown"
                android:layout_width="match_parent"
                android:layout_height="@dimen/tegula_touch_target" />
        </LinearLayout>

        <Button
            android:id="@+id/swapButton"
            style="@style/Widget.Tegula.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/tegula_spacing_sm"
            android:layout_marginEnd="@dimen/tegula_spacing_sm"
            android:minWidth="@dimen/tegula_touch_target"
            android:text="@string/swap" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="To"
                android:textColor="@color/tegula_text_secondary"
                android:textSize="@dimen/tegula_text_xs"
                android:textStyle="bold" />

            <include
                android:id="@+id/targetDropdown"
                layout="@layout/tegula_dropdown"
                android:layout_width="match_parent"
                android:layout_height="@dimen/tegula_touch_target" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/imageContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="@dimen/tegula_spacing_md"
        android:layout_weight="1">

        <EditText
            android:id="@+id/inputText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/tegula_card_bg"
            android:gravity="top"
            android:hint="@string/enter_text"
            android:inputType="textMultiLine"
            android:padding="@dimen/tegula_spacing_lg"
            android:textColor="@color/tegula_text_primary"
            android:textColorHint="@color/tegula_text_secondary"
            android:textSize="@dimen/tegula_text_md"
            android:scrollbars="vertical" />

        <com.venddair.interpres.ZoomImageView
            android:id="@+id/overlayImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/tegula_card_bg"
            android:visibility="gone" />

    </FrameLayout>

    <TextView
        android:id="@+id/outputText"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/tegula_card_bg"
        android:padding="@dimen/tegula_spacing_lg"
        android:scrollbars="vertical"
        android:textColor="@color/tegula_text_primary"
        android:textIsSelectable="true"
        android:textSize="@dimen/tegula_text_md" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/tegula_spacing_md"
        android:layout_marginBottom="@dimen/tegula_spacing_md"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/cameraButton"
            style="@style/Widget.Tegula.Button"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/tegula_spacing_sm"
            android:contentDescription="@string/scan_image"
            android:src="@android:drawable/ic_menu_camera"
            android:paddingStart="0dp"
            android:paddingEnd="0dp" />

        <Button
            android:id="@+id/translateButton"
            style="@style/Widget.Tegula.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/translate" />

        <ImageButton
            android:id="@+id/clearButton"
            style="@style/Widget.Tegula.Button"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/tegula_spacing_sm"
            android:contentDescription="Clear input"
            android:src="@android:drawable/ic_menu_close_clear_cancel" />
    </LinearLayout>
</LinearLayout>
